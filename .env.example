# =============================================================
# TaskFlow —— docker-compose 启动用的环境变量
#
# 用法:
#   cp .env.example .env
# 然后按需修改各项;.env 不要 commit 到 git。
# 没有列在这里的变量,看 server/.env.example(纯本地启动 Go 后端时使用)。
# =============================================================

# ── 必须项:JWT 密钥(最少 32 字符随机串) ───────────────────────────────
# 生成:openssl rand -hex 32
TASKFLOW_JWT_SECRET=please-replace-me-with-openssl-rand-hex-32-output-min32chars

# ── 首次启动管理员 ────────────────────────────────────────────────────────
# 容器首次启动时:
#   - 若 users 表里已经有同邮箱用户 -> 提升为管理员(密码不会被覆盖)
#   - 若不存在 -> 用下面的密码新建一个管理员账号(密码至少 8 位)
# 上线后建议立刻在 web 端把这个账号的密码改掉,然后从 .env 中清空 ADMIN_PASSWORD。
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMeNow123!

# ── 对外端口 ────────────────────────────────────────────────────────────
# web 容器暴露给宿主机的端口,默认 8080(浏览器访问 http://localhost:8080)。
# 单机直接在 80 端口对外可改成 80。
WEB_PORT=8080

# ── 时区 / 日志 ─────────────────────────────────────────────────────────
TZ=Asia/Shanghai
TASKFLOW_LOG_LEVEL=info

# ── 公网根 URL(强烈建议设置) ────────────────────────────────────────────
# 用户浏览器看到的 TaskFlow 根地址。设置后:
#   - OAUTH_REDIRECT_URL / OAUTH_FRONTEND_REDIRECT_URL 留空时按它推导
#     -> redirect:  ${PUBLIC_BASE_URL}/api/auth/oauth/callback
#     -> frontend:  ${PUBLIC_BASE_URL}/oauth/callback
#   - Windows / Android 客户端可以以它作为默认服务端地址(VITE_TASKFLOW_SERVER_URL)
#
# 示例:
#   生产:  PUBLIC_BASE_URL=https://taskflow.teamcy.eu.cc
#   本地:  PUBLIC_BASE_URL=http://127.0.0.1:8080
PUBLIC_BASE_URL=

# ── Telegram(可选,留空 = 关闭) ────────────────────────────────────────
TASKFLOW_TG_BOT_TOKEN=
TASKFLOW_TG_BOT_USER=
TASKFLOW_TG_WEBHOOK_SEC=

# ── OAuth2 / OIDC 认证中心(可选) ──────────────────────────────────────
# 启用后,本地邮箱注册/登录会被关闭;前端只显示"通过认证中心登录"按钮。
# 注意:这种情况下 ADMIN_EMAIL 仍能工作 —— 第一次以该邮箱登录后,引导逻辑会把
# 这个 OAuth 账号提升为管理员。
OAUTH_ENABLED=false
OAUTH_PROVIDER=

# !!! 关键 !!! Profile 项目用的是 hash 路由,授权 URL 必须带 /#/ 。
#    https://teamcy.eu.cc/#/oauth/authorize     ✅
#    https://teamcy.eu.cc/oauth/authorize       ❌(404,Profile 后端没有这个路径)
OAUTH_AUTHORIZE_URL=

OAUTH_TOKEN_URL=
OAUTH_USERINFO_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# 留空则按 PUBLIC_BASE_URL 自动推导(推荐留空)。
OAUTH_REDIRECT_URL=
OAUTH_FRONTEND_REDIRECT_URL=

OAUTH_SCOPES=openid profile email
