# =============================================================
# TaskFlow —— 项目唯一的环境变量文件
#
# 用法:
#   cp .env.example .env        # 然后按需修改下面各项
#   .env 不要 commit 到 git。
#
# 设计原则:
#   * 三端(server / web / windows / android)都从这一个 .env 读配置;
#     不再有 server/.env、windows/.env 之类的子目录配置。
#   * 前后端分离部署:
#     - 前端(用户)   = ${PUBLIC_BASE_URL}  = taskflow.teamcy.eu.cc
#     - 后端(API)    = ${PUBLIC_API_URL}   = backend.taskflow.teamcy.eu.cc
#   * 开发时两个都指向 localhost,上线后各自替换。
# =============================================================


# ─────────────────────────────────────────────────────────────
# 1. 前端域名 —— 用户浏览器访问的 Web 前端
# ─────────────────────────────────────────────────────────────
# 决定:
#   - OAUTH_FRONTEND_REDIRECT_URL 推导
#   - Vite dev proxy target (开发模式)
#   - OAuth 登录完成后浏览器跳回的地址
#
# 开发:  PUBLIC_BASE_URL=http://127.0.0.1:3003
# 生产:  PUBLIC_BASE_URL=https://taskflow.teamcy.eu.cc
PUBLIC_BASE_URL=http://127.0.0.1:3003

# ─────────────────────────────────────────────────────────────
# 1b. 后端 API 域名 —— 客户端(Win/Android)与服务端通信的地址
# ─────────────────────────────────────────────────────────────
# 决定:
#   - OAUTH_REDIRECT_URL 推导 (OAuth 回调 endpoint 在后端)
#   - Tauri 编译时烧入的"出厂默认服务端 URL"
#   - Android 编译时烧入的 BuildConfig.DEFAULT_SERVER_URL
#
# 开发:  PUBLIC_API_URL=http://127.0.0.1:8080
# 生产:  PUBLIC_API_URL=https://backend.taskflow.teamcy.eu.cc
PUBLIC_API_URL=http://127.0.0.1:8080


# ─────────────────────────────────────────────────────────────
# 2. 后端核心
# ─────────────────────────────────────────────────────────────
# JWT 签名密钥(>=32 字符随机串)。生成: openssl rand -hex 32
TASKFLOW_JWT_SECRET=please-replace-me-with-openssl-rand-hex-32-output-min32chars

# 后端监听地址。docker 部署时容器内会强制 0.0.0.0:8080,本字段只影响裸进程。
TASKFLOW_LISTEN=127.0.0.1:8080

# SQLite 文件路径(相对路径相对于工作目录)
TASKFLOW_DB_PATH=data/taskflow.db

# debug | info | warn | error
TASKFLOW_LOG_LEVEL=info

# 时区(影响日志时间戳;数据按 UTC 存)
TZ=Asia/Shanghai


# ─────────────────────────────────────────────────────────────
# 3. 首次启动管理员引导
# ─────────────────────────────────────────────────────────────
# 容器/进程首次启动时:
#   - users 表里已有同邮箱用户   -> 提升为管理员(密码不会被覆盖)
#   - 不存在                     -> 用 ADMIN_PASSWORD 新建管理员(密码至少 8 位)
# 上线后立刻在 web 端把这个账号的密码改掉,然后从 .env 中清空 ADMIN_PASSWORD。
#
# 注意:OAuth 模式(OAUTH_ENABLED=true)下,本地密码无效;ADMIN_EMAIL 仍生效 ——
# 第一次以该邮箱通过 OAuth 登录后,会自动被提升为管理员。
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMeNow123!


# ─────────────────────────────────────────────────────────────
# 4. 前端 Vite 开发服务器(仅 dev 模式用)
# ─────────────────────────────────────────────────────────────
# `npm run dev` 时 Vite 监听这里。/api 与 /ws 由 vite proxy 代到 PUBLIC_API_URL。
WEB_DEV_HOST=127.0.0.1
WEB_DEV_PORT=3003

# Tauri 客户端 dev 模式专用端口(Cargo 与 Vite 必须一致)
TAURI_DEV_PORT=1420


# ─────────────────────────────────────────────────────────────
# 5. docker-compose 对外端口
# ─────────────────────────────────────────────────────────────
# web 容器暴露给宿主机的端口。单机直接挂 80 改成 80。
WEB_PORT=8080


# ─────────────────────────────────────────────────────────────
# 6. OAuth2 / OIDC 认证中心(必填,本项目强制 OAuth 登录)
# ─────────────────────────────────────────────────────────────
# 三端登录都走 OAuth;本地邮箱注册/登录端点已被服务端关闭。
# 桌面 / 移动端通过"系统浏览器 + 服务端轮询 (poll)"获取登录态。
#
# 在 Profile 后台 (https://teamcy.eu.cc/#/admin/oauth-clients) 创建客户端:
#   应用名称  = TaskFlow
#   Client ID = 自定义,例如 TaskFlow_Client_ID
#   主页 URL  = ${PUBLIC_BASE_URL}/
#   回调 URI  = ${PUBLIC_API_URL}/api/auth/oauth/callback
# 保存后会拿到 Client Secret,粘贴到 OAUTH_CLIENT_SECRET。

OAUTH_ENABLED=true

# 提供方标识符,会写到 users.oauth_provider 列。
OAUTH_PROVIDER=teamcy.eu.cc

# !!! 关键 !!! Profile 项目用的是 hash 路由,授权 URL 必须带 /#/ 。
OAUTH_AUTHORIZE_URL=https://teamcy.eu.cc/#/oauth/authorize
OAUTH_TOKEN_URL=https://teamcy.eu.cc/api/oauth/token
OAUTH_USERINFO_URL=https://teamcy.eu.cc/api/oauth/userinfo

OAUTH_CLIENT_ID=TaskFlow_Client_ID
OAUTH_CLIENT_SECRET=PASTE_CLIENT_SECRET_HERE

# 留空 = 自动推导(推荐)
# OAUTH_REDIRECT_URL          → ${PUBLIC_API_URL}/api/auth/oauth/callback
# OAUTH_FRONTEND_REDIRECT_URL → ${PUBLIC_BASE_URL}/oauth/callback
OAUTH_REDIRECT_URL=
OAUTH_FRONTEND_REDIRECT_URL=

# 授权 scope
OAUTH_SCOPES=openid profile email

# userinfo 字段名
OAUTH_EMAIL_FIELD=email
OAUTH_NAME_FIELD=name
OAUTH_SUBJECT_FIELD=sub


# ─────────────────────────────────────────────────────────────
# 7. Android APK 签名(仅 release 构建需要)
# ─────────────────────────────────────────────────────────────
# 生成 keystore:
#   keytool -genkey -v -keystore taskflow-release.keystore -alias taskflow -keyalg RSA -keysize 2048 -validity 10000
# 将 .keystore 放到 android/app/ 下,然后填入密码。
# 留空 = release 构建生成未签名 APK。
ANDROID_KEYSTORE_PATH=android/app/taskflow-release.keystore
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=taskflow
ANDROID_KEY_PASSWORD=

# ─────────────────────────────────────────────────────────────
# 8. Telegram(可选,留空 = 关闭)
# ─────────────────────────────────────────────────────────────
TASKFLOW_TG_BOT_TOKEN=
TASKFLOW_TG_BOT_USER=
TASKFLOW_TG_WEBHOOK_SEC=
