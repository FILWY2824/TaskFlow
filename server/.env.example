# =============================================================
# TaskFlow 服务端环境变量
# =============================================================
# 复制本文件为 .env 后修改使用:
#     cp .env.example .env
# 服务进程启动时会自动从工作目录的 .env 文件读取这些变量。
# 进程已经存在的环境变量优先,.env 文件不会覆盖它(便于 systemd / docker 注入)。
# .env 文件不要 commit 到 git(已在 .gitignore 中)。

# -------------------------------------------------------------
# 公网根 URL(强烈建议设置)
# -------------------------------------------------------------
# 这是 TaskFlow 部署后用户浏览器看到的根地址。设置后:
#   - OAUTH_REDIRECT_URL / OAUTH_FRONTEND_REDIRECT_URL 留空时会按它推导
#     -> redirect:  ${PUBLIC_BASE_URL}/api/auth/oauth/callback
#     -> frontend:  ${PUBLIC_BASE_URL}/oauth/callback
#   - 不设置也可以 —— 那就必须把所有 OAUTH_*_URL 全部明确填写。
#
# 示例:
#   生产:  PUBLIC_BASE_URL=https://taskflow.teamcy.eu.cc
#   本地:  PUBLIC_BASE_URL=http://127.0.0.1:8080
PUBLIC_BASE_URL=

# -------------------------------------------------------------
# OAuth2 / OIDC 认证中心
# -------------------------------------------------------------
# 启用后:
#   - 本地邮箱注册/登录端点会被关闭(返回 403)。
#   - 前端登录页只显示「通过认证中心登录」按钮。
#   - 服务端在认证中心回调里换 token + 拉 userinfo,upsert 本地用户后
#     签发本服务的 JWT(access + refresh)。
#
# 你需要在认证中心(Profile 后台 https://teamcy.eu.cc/#/admin/oauth-clients)
# 创建一个客户端:
#   应用名称   = TaskFlow
#   Client ID  = 自定义,例如 TaskFlow_Client_ID(写入 OAUTH_CLIENT_ID)
#   主页 URL   = ${PUBLIC_BASE_URL}/         例如 https://taskflow.teamcy.eu.cc/
#   Logo URL   = 可选,留空即可
#   回调 URI   = 必须与下面 OAUTH_REDIRECT_URL 逐字符一致
#                生产: ${PUBLIC_BASE_URL}/api/auth/oauth/callback
# 保存后认证中心会生成 Client Secret,粘贴到 OAUTH_CLIENT_SECRET。

OAUTH_ENABLED=true

# 提供方标识符,写入数据库 users.oauth_provider 列。建议用域名。
# 一旦上线就别改 —— 改了等于让已绑定的用户失联。
OAUTH_PROVIDER=teamcy.eu.cc

# 授权端点(浏览器会被 302 到这里登录)。
# !!! 关键 !!! Profile 项目用的是 hash 路由(SPA),所以这里必须带 /#/ 。
# 写成 https://teamcy.eu.cc/oauth/authorize 不会工作 —— 后端没有这个路径,
# 真实的同意页面是前端 Vue 路由 /#/oauth/authorize。
OAUTH_AUTHORIZE_URL=https://teamcy.eu.cc/#/oauth/authorize

# 令牌端点(服务端用 code + client_secret 换 access_token)
OAUTH_TOKEN_URL=https://teamcy.eu.cc/api/oauth/token

# 用户信息端点(服务端拿 access_token 调用,返回 sub/email/name)
OAUTH_USERINFO_URL=https://teamcy.eu.cc/api/oauth/userinfo

# 在认证中心客户端配置里填的 Client ID
OAUTH_CLIENT_ID=TaskFlow_Client_ID

# 在认证中心创建客户端后拿到的 Client Secret(当作密码保管,绝不进 git)
OAUTH_CLIENT_SECRET=PASTE_CLIENT_SECRET_HERE

# 我方接收回调的完整 URL。必须与认证中心客户端的「回调 URI」逐字符一致。
# 留空则按 ${PUBLIC_BASE_URL}/api/auth/oauth/callback 推导(推荐留空,改 PUBLIC_BASE_URL 即可)。
OAUTH_REDIRECT_URL=

# 服务端处理完 OAuth 后,把用户重定向回前端这个 URL,并在 fragment(#)
# 里带 handoff_code。留空则按 ${PUBLIC_BASE_URL}/oauth/callback 推导(推荐留空)。
OAUTH_FRONTEND_REDIRECT_URL=

# 授权 scope。留空 = "openid profile email"(OIDC 默认三件套)。
# 支持空格或逗号分隔,例如 "openid profile email"  或  "openid,profile,email"
OAUTH_SCOPES=openid profile email

# userinfo 响应字段名。多数实现用 sub / email / name,一般保持默认即可。
# 如你认证中心用的是 user_id / mail / nickname 这种,在这里改。
OAUTH_EMAIL_FIELD=email
OAUTH_NAME_FIELD=name
OAUTH_SUBJECT_FIELD=sub
