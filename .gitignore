# ==============================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# ==============================
# Env & secrets (only .env.example is committed)
# ==============================
.env
.env.local
.env.*.local

# ==============================
# Go backend (/server)
# ==============================
/server/taskflow-server*
/server/dist/
/server/data/
/server/*.db
/server/*.db-wal
/server/*.db-shm
/server/*.log
/server/vendor/
/server/config.toml
/server/.gocache/

# 数据文件(保留目录结构,只忽略内容)
/data/*
!/data/.gitkeep
/server/data/
/backup/

# ==============================
# Node / Frontend (/web & /windows)
# ==============================
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log
yarn-error.log
pnpm-debug.log
.npm/
*.tsbuildinfo

# ==============================
# Rust / Tauri (/windows)
# ==============================
/windows/src-tauri/target/
# Tauri build 产物的 schemas 由 tauri-build 在每次编译时重建,不需要进 git。
/windows/src-tauri/gen/
**/*.rs.bk

# ==============================
# Android (/android)
# ==============================
/android/.gradle/
/android/.gradle-user-home/
/android/.gradle-project-cache/
/android/.android-sdk-home/
/android/.android-user-home/
/android/build/
/android/app/build/
/android/local.properties
/android/.cxx/
/android/.kotlin/
*.keystore
# APK / AAB:只忽略 android/ 下的构建散碎;releases/ 下的正式包要提交。
/android/**/*.apk
/android/**/*.aab

# ==============================
# 下载 / 发布目录 —— 用户下载的产物,必须提交
# ==============================
!releases/
!releases/**/

