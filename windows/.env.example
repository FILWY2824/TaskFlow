# =============================================================
# TaskFlow Windows 客户端打包参数
# =============================================================
# 复制为 windows/.env(同目录),npm run tauri:build 时会被自动加载。
#
# 这些 env 不会进 Tauri 进程的运行时 —— 它们是给 Vite 与 Cargo 在
# 编译/打包"那一刻"用的,用来把"出厂默认服务端 URL"烧进 .msi/.exe。
# 安装的用户启动客户端后,如果还没改过 server URL,就会用这个值连后端。
# =============================================================

# 打包时烧进二进制的默认服务端 URL。运行时用户可以在「设置」里改,
# 改完会持久化到 %APPDATA%\TaskFlow\config.json,优先级高于本字段。
#
# 必须是 http:// 或 https:// 开头的完整 URL,末尾不要带斜杠。
# 示例:
#   生产:  VITE_TASKFLOW_DEFAULT_SERVER=https://taskflow.teamcy.eu.cc
#   本地:  VITE_TASKFLOW_DEFAULT_SERVER=http://127.0.0.1:8080
VITE_TASKFLOW_DEFAULT_SERVER=https://taskflow.teamcy.eu.cc

# 同名值也注入给 Rust(编译时通过 option_env!() 读取),供后台 sync loop
# 在用户尚未交互时使用。两者保持一致即可。
TASKFLOW_DEFAULT_SERVER_URL=https://taskflow.teamcy.eu.cc
