{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TaskFlow",
  "version": "0.4.0",
  "identifier": "com.taskflow.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TaskFlow",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: asset:; script-src 'self' 'unsafe-inline' 'unsafe-eval' tauri:; style-src 'self' 'unsafe-inline' tauri:; img-src 'self' tauri: asset: data: blob: https: http:; connect-src 'self' tauri: ipc: asset: https: http: ws: wss:; font-src 'self' tauri: data:; worker-src 'self' tauri: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "TaskFlow 桌面客户端",
    "longDescription": "多用户 TODO + 强提醒,Windows 端本地强提醒 + 系统托盘 + 开机启动。数据保存在安装目录 data/ 下,便于迁移备份。",
    "publisher": "TaskFlow",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": false
      },
      "wix": {
        "language": ["zh-CN", "en-US"]
      }
    }
  },
  "plugins": {}
}
